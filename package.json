{
  "name": "quiz-room-auto",
  "version": "1.0.0",
  "description": "Automated quiz room system for commercial quiz venues",
  "main": "backend/src/server.js",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev": "nodemon backend/src/server.js",
    "test": "jest --forceExit",
    "build:frontend": "cd frontend && npm run build"
  },
  "keywords": [
    "quiz",
    "trivia",
    "websocket",
    "real-time",
    "automated"
  ],
  "author": "EduardIng",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.5.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "clearMocks": true
  }
}